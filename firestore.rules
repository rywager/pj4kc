rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Volunteer signups - write-only from public
    match /volunteers/{docId} {
      allow create: if request.resource.data.keys().hasAll(['name', 'email'])
        && request.resource.data.name is string
        && request.resource.data.email is string
        && request.resource.data.name.size() < 200
        && request.resource.data.email.size() < 200;
      allow read, update, delete: if false;
    }
    // Email list signups
    match /subscribers/{docId} {
      allow create: if request.resource.data.keys().hasAll(['email'])
        && request.resource.data.email is string
        && request.resource.data.email.size() < 200;
      allow read, update, delete: if false;
    }
  }
}
